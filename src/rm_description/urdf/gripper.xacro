<?xml version="1.0" encoding="utf-8"?>
<!-- 夹爪宏定义 -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="gripper_part">
  
  <xacro:macro name="gripper_macro">
    <link name="link_gripper_up">
      <inertial>
        <origin xyz="0.0083932168000731 -0.0010841758069529 -0.0718783541077461" rpy="0 0 0" />
        <mass value="0.0740919747276391" />
        <inertia ixx="1.65736896989218E-05" ixy="-1.13479059082368E-08" ixz="1.84490869096458E-06"
                 iyy="3.67103204844643E-05" iyz="4.75930254646595E-08" izz="2.74771531788551E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://rm_description/meshes/link_gripper_up.STL" />
        </geometry>
        <material name="">
          <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://rm_description/meshes/link_gripper_up.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="joint_gripper_up" type="prismatic">
      <origin xyz="0 0 0.101" rpy="3.14159265358979 1.5707963267949 0" />
      <parent link="link_6" />
      <child link="link_gripper_up" />
      <axis xyz="0 0 -1" />
      <limit lower="-0.03" upper="0" effort="2.5" velocity="2" />
    </joint>

    <link name="link_gripper_down">
      <inertial>
        <origin xyz="0.00745363380751052 0.0010841758069837 0.0718783541077476" rpy="0 0 0" />
        <mass value="0.0740919747276391" />
        <inertia ixx="1.65736896989218E-05" ixy="1.13479059083673E-08" ixz="-1.84490869096458E-06"
                 iyy="3.67103204844644E-05" iyz="4.75930254646657E-08" izz="2.74771531788552E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://rm_description/meshes/link_gripper_down.STL" />
        </geometry>
        <material name="">
          <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
        </material>
