    <joint name="joint_gripper_down" type="prismatic">
      <origin xyz="0 0 0.101" rpy="3.14159265358979 1.5707963267949 0" />
      <parent link="link_6" />
      <child link="link_gripper_down" />
      <axis xyz="0 0 -1" />
      <limit lower="-0.03" upper="0.03" effort="2.5" velocity="2" />
      <mimic joint="joint_gripper_up" multiplier="-1.0" />
    </joint>
  </xacro:macro>
  
